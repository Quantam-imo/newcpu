[Unit]
Description=AstroQuant System Health Check
After=astroquant_orchestrator.service astroquant_celery.service astroquant_calibrate.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/workspaces/newcpu
ExecStart=/bin/bash /workspaces/newcpu/health_check.sh
TimeoutSec=60

[Install]
WantedBy=multi-user.target