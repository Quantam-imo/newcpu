# AstroQuant Environment Variables Example
# Copy this file to .env and fill in your secrets

# Databento API Key (required for live/historical market data)
DATABENTO_API_KEY=your_databento_api_key_here

# Chrome DevTools Protocol (CDP) endpoint (default for local Chrome)
CDP_ENDPOINT=ws://127.0.0.1:9222
EXECUTION_BROWSER_CDP_URL=ws://127.0.0.1:9222
EXECUTION_BROWSER_AUTO_ATTACH=true
EXECUTION_BROWSER_TIMEOUT_MS=30000

# Order Execution
ORDER_EXECUTION_MODE=confirm-token
ORDER_SYMBOL_LOCK=true
ORDER_MICRO_LOT_SIZE=0.01

# Risk Management
DAILY_LOSS_LIMIT_USD=500
MAX_CONCURRENT_POSITIONS=3
DRAWDOWN_MAX_PERCENT=10

# Add any other secrets or environment variables required by your deployment below
# Example:
# BROKER_USERNAME=your_broker_username
# BROKER_PASSWORD=your_broker_password
