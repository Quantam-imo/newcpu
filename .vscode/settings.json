{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/__pycache__/**": true,
    "**/.venv/**": true,
    "**/node_modules/**": true,
    "**/logs/**": true,
    "**/browser_session/**": true,
    "**/Default/Code Cache/**": true,
    "**/Default/GPUCache/**": true,
    "**/Default/Session Storage/**": true,
    "**/Default/Local Storage/**": true,
    "**/Default/shared_proto_db/**": true,
    "**/Default/DawnGraphiteCache/**": true,
    "**/Default/DawnWebGPUCache/**": true,
    "**/*.pyc": true,
    "**/data/playwright_*/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/browser_session": true,
    "**/Default/Code Cache": true,
    "**/Default/GPUCache": true,
    "**/Default/Session Storage": true,
    "**/Default/Local Storage": true,
    "**/Default/shared_proto_db": true,
    "**/Default/DawnGraphiteCache": true,
    "**/Default/DawnWebGPUCache": true,
    "**/data/playwright_user": true,
    "**/data/playwright_matchtrader": true,
    "**/logs": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.venv": true,
    "**/logs": true,
    "**/browser_session": true,
    "**/Default/Code Cache": true,
    "**/Default/GPUCache": true,
    "**/Default/Session Storage": true,
    "**/Default/Local Storage": true,
    "**/Default/shared_proto_db": true,
    "**/Default/DawnGraphiteCache": true,
    "**/Default/DawnWebGPUCache": true,
    "**/data/playwright_*": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true
  },
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.indexing": false,
  "python.analysis.autoImportCompletions": false,
  "python.analysis.exclude": [
    "**/.venv/**",
    "**/__pycache__/**",
    "**/browser_session/**",
    "**/*.pyc",
    "**/logs/**",
    "**/data/**",
    "**/AstroQuant_Phase1/data/**"
  ],
  "python.analysis.userFileIndexingLimit": 2000,
  "python.analysis.languageServerMode": "light",
  "git.decorations.enabled": false,
  "git.autorefresh": false,
  "typescript.tsserver.maxTsServerMemory": 1024
}
