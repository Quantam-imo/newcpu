# AstroQuant Production Environment Configuration Template
# Copy to .env and fill in actual values

# =============================================================================
# Backend Configuration
# =============================================================================

# FastAPI Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_WORKERS=4
FASTAPI_LOG_LEVEL=info

# Frontend
FRONTEND_BASE_URL=http://localhost:8000
FRONTEND_CACHE_ENABLED=true
FRONTEND_PERF_DASHBOARD_ENABLED=true

# =============================================================================
# Broker Integration (CRITICAL for live trading)
# =============================================================================

# Chrome DevTools Protocol (CDP) for Playwright
CDP_ENDPOINT=ws://127.0.0.1:9222              # ← Update with actual CDP endpoint
CDP_TIMEOUT_SEC=30
CDP_RECONNECT_RETRIES=3
CDP_RECONNECT_DELAY_MS=5000

# Broker Configuration
BROKER_NAME=MatchTrader                         # or IB, ThinkorSwim, etc.
BROKER_ACCOUNT_ID=YOUR_ACCOUNT_ID               # Replace with actual
BROKER_API_KEY=YOUR_API_KEY                     # Never commit real keys!
BROKER_API_URL=https://api.broker.com           # Broker endpoint

# Order Entry
ORDER_EXECUTION_MODE=confirm-token              # Options: dry-run, confirm-token, auto
ORDER_SYMBOL_LOCK=true                          # Prevent wrong symbol orders
ORDER_MICRO_LOT_SIZE=0.01                       # Start with micro for validation
ORDER_SLIPPAGE_TOLERANCE_PIP=2                  # Accept max N pips slippage

# =============================================================================
# Market Data Feed
# =============================================================================

# Live Pricing (for mentor data)
MARKET_DATA_PROVIDER=broker                     # Options: broker, external, cache
MARKET_DATA_REFRESH_SEC=1                       # Update interval
LIVE_PRICE_TIMEOUT_SEC=30                       # Max staleness tolerance

# Orderflow Data
ORDERFLOW_BUFFER_SIZE=500                       # Max orders to track
ORDERFLOW_UPDATE_INTERVAL_MS=500                # Refresh interval

# =============================================================================
# Execution & Risk Management
# =============================================================================

# Position Management
MAX_CONCURRENT_POSITIONS=3                      # Preventing over-leverage
MAX_POSITION_SIZE_LOT=1.0                       # Start small for validation
POSITION_RECONCILIATION_INTERVAL_SEC=5          # How often to verify

# Risk Controls
DAILY_LOSS_LIMIT_USD=500                        # Stop trading if exceeded
ACCOUNT_EQUITY_MIN_USD=10000                    # Minimum equity requirement
DRAWDOWN_MAX_PERCENT=10                         # Max account drawdown %
CORRELATION_MULTIPLIER=1.0                      # Risk adjustment

# Stop Loss / Take Profit
DEFAULT_SL_PERCENT=2.0                          # 2% stop loss
DEFAULT_TP_PERCENT=3.0                          # 3% take profit
TRAILING_STOP_PERCENT=1.5                       # Trail stops by X%
TP_BREAKEVEN_AT_PERCENT=1.0                     # Lock in profits at X%

# =============================================================================
# Mentor Engine Configuration
# =============================================================================

# Data Freshness
MENTOR_CACHE_TTL_SEC=8                          # Match polling interval
MENTOR_DATA_MAX_AGE_SEC=30                      # Stale data threshold
MENTOR_POLLING_INTERVAL_SEC=8                   # How often to update

# Signal Confidence
MENTOR_SIGNAL_THRESHOLD=0.6                     # Min confidence for entry
MENTOR_ICEBERG_STRENGTH_MIN=0.7                 # Min iceberg strength
MENTOR_ORDERFLOW_MIN_IMBALANCE=0.65             # Min orderflow ratio

# =============================================================================
# Chart & Technical Analysis
# =============================================================================

# Chart Caching
CHART_CACHE_TTL_SEC=3                           # Short TTL for charts
CHART_MAX_SYMBOLS=10                            # Max concurrent charts
CHART_CANDLE_LIMIT=220                          # Candles to load
CHART_OVERLAY_ENABLED=true                      # Draw mentor overlays

# Technical Indicators
VWAP_ENABLED=true
ATR_ENABLED=true
VOLUME_PROFILE_ENABLED=true
ORDER_BLOCK_DETECTION=true
ICE_BAG_DETECTION=true
LIQUIDITY_SWEEP_DETECTION=true

# =============================================================================
# Performance & Optimization
# =============================================================================

# Frontend Performance
FRONTEND_PERF_TRACKING=true                     # Track request metrics
FRONTEND_ERROR_RETRY_ENABLED=true               # Auto-retry on errors
FRONTEND_ERROR_RETRY_DELAY_MS=2000              # Wait before retry
FRONTEND_HEALTH_CHECK_INTERVAL_SEC=30           # Backend ping interval

# Caching Strategy
CACHE_ENDPOINT_TTL_MENTOR=8000                  # milliseconds
CACHE_ENDPOINT_TTL_CHART=3000
CACHE_ENDPOINT_TTL_ORDERFLOW=5000
CACHE_ENDPOINT_TTL_OFFSET=10000

# Request Timeouts
REQUEST_TIMEOUT_CHART_MS=18000                  # 18s for slow endpoints
REQUEST_TIMEOUT_MENTOR_MS=25000                 # 25s for mentor
REQUEST_TIMEOUT_STATUS_MS=5000                  # 5s for health checks
REQUEST_TIMEOUT_DEFAULT_MS=10000                # 10s default

# =============================================================================
# Logging & Monitoring
# =============================================================================

# Log Levels
LOG_LEVEL_BACKEND=info                          # debug, info, warning, error
LOG_LEVEL_FRONTEND=info
LOG_LEVEL_EXECUTION=info
LOG_LEVEL_MENTOR=info

# Log Rotation
LOG_MAX_SIZE_MB=100
LOG_RETENTION_DAYS=30
LOG_FORMAT=json                                 # json or plaintext

# Monitoring
MONITORING_ENABLED=true
METRICS_COLLECTION_INTERVAL_SEC=60
ALERTS_EMAIL=your-email@example.com             # Optional
SLACK_WEBHOOK_URL=                              # Optional

# =============================================================================
# Database & Persistence
# =============================================================================

# SQLite Database
DATABASE_PATH=astroquant/data/production.db
DATABASE_BACKUP_INTERVAL_HOUR=4
DATABASE_BACKUP_RETENTION_DAYS=7

# Cache Strategy
CACHE_STORAGE=localStorage                      # localStorage for browser
CACHE_MAX_SIZE_BYTES=5242880                    # 5MB limit

# =============================================================================
# Security & Authentication
# =============================================================================

# Admin Access
ADMIN_TOKEN=your-secure-admin-token-here        # Never the default!
ADMIN_USER=admin
ADMIN_ROLE=ADMIN

# API Security
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
RATE_LIMIT_ENABLED=false                        # Disabled for internal use
SESSION_TIMEOUT_MINUTES=480                     # 8 hours

# =============================================================================
# Deployment & Environment
# =============================================================================

# Environment
ENVIRONMENT=production                          # production, staging, development
HOSTNAME=                                       # Your production server hostname
PYTHON_ENV=astroquant                           # Virtual environment name

# Debugging
DEBUG_MODE=false                                # NEVER enable in production
VERBOSE_LOGGING=false                           # More detailed logs
PROFILING_ENABLED=false                         # CPU/memory profiling

# Backups
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily                           # daily, hourly, manual
BACKUP_RETENTION_DAYS=30

# =============================================================================
# Pre-Launch Validation
# =============================================================================

# This section is filled by deployment scripts
# DO NOT EDIT MANUALLY

PRE_LAUNCH_VALIDATED=false
PRE_LAUNCH_TIMESTAMP=
PRE_LAUNCH_VALIDATOR=
CDP_CONNECTION_VERIFIED=false
ORDER_ENTRY_TESTED=false
MENTOR_DATA_VERIFIED=false
CHART_DATA_VERIFIED=false

# =============================================================================
# Notes for Setup
# =============================================================================

# 1. CDP Endpoint
#    - Find it by running: chrome://inspect (in Chrome DevTools)
#    - Or manually start: chrome --remote-debugging-port=9222
#
# 2. Broker Credentials
#    - Never commit real API keys to git
#    - Use environment variable substitution
#    - Rotate keys after each deployment
#
# 3. Risk Limits
#    - Scale up gradually (micro → mini → standard)
#    - Start with DAILY_LOSS_LIMIT=100, max position=0.01 lot
#    - Monitor first day with alerts enabled
#
# 4. Order Entry Modes
#    - dry-run:      Simulates orders (for testing)
#    - confirm-token: Requires manual approve in DOM
#    - auto:         Automatic (dangerous - avoid)
#
# 5. Cache Configuration
#    - Increase TTL for stale-safe data
#    - Decrease TTL for real-time data
#    - Monitor cache hit rates in dashboard
#
# 6. Performance Tuning
#    - Monitor metrics at: http://localhost:8000/frontend (📊 Perf button)
#    - Adjust timeouts if requests timeout
#    - Cache hit rate target: 15-25%
#

# =============================================================================
# Quick Reference: Common Deployments
# =============================================================================

# For Staging/Testing:
#   export $(cat .env | xargs)
#   python -m pytest -v
#   python -m uvicorn astroquant.backend.main:app --reload

# For Production (Small Account):
#   ORDER_EXECUTION_MODE=confirm-token
#   ORDER_MICRO_LOT_SIZE=0.01
#   DAILY_LOSS_LIMIT_USD=100
#   MAX_POSITION_SIZE_LOT=0.1

# For Production (Full Account):
#   ORDER_EXECUTION_MODE=auto
#   ORDER_MICRO_LOT_SIZE=0.1
#   DAILY_LOSS_LIMIT_USD=500
#   MAX_POSITION_SIZE_LOT=1.0

